# gRPC API server URL (host:port).
# Production: api.zhuzh.dev:443
# Local dev: localhost:50051 after port-forward (kubectl port-forward svc/zhuzh-api-svc 50051:8001)
GRPC_API_SERVER_URL=

# Cookie encryption: base64-encoded 32-byte key for AES-256-GCM.
# Generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# Cookie name (default: admin_webapp)
COOKIE_NAME=admin_webapp

# Cookie domain (optional, e.g. admin.zhuzh.dev)
COOKIE_DOMAIN=admin.zhuzh.dev

# Set to 'true' for local dev (insecure gRPC)
DEVELOPING_LOCALLY=
